# Agent Farm — copy to .env and fill in as needed

# LLM (OpenRouter or OpenAI)
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# LLM_MODEL=openrouter/free
# USE_LLM=0
# LLM_EVERY_N_TICKS=1

# Tavily (Researcher agent)
# TAVILY_API_KEY=

# PixelLab (Architect/Builder pixel art; optional)
# Get token from https://www.pixellab.ai
# PIXELLAB_API_TOKEN=

# Ports (optional)
# RUNTIME_PORT=3011
# VITE_SEARCH_API_URL=http://localhost:3010
